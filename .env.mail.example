# ─────────────────────────────────────────────────────────────────────────────
# Beam — mail config. Copy these lines into your real backend/.env and fill in
# the two secrets. (Never commit the filled-in .env — it holds credentials.)
#
# ⚠️ The Gmail "app password" you shared in chat is now exposed — revoke it at
#    Google Account → Security → App passwords, generate a fresh one, and put
#    THAT here. App passwords are 16 chars; paste WITHOUT spaces.
# ─────────────────────────────────────────────────────────────────────────────

# Make sure the app name is set — MAIL_FROM_NAME below inherits it, so every
# Beam email (verify / reset / download alert) is signed "Beam".
APP_NAME=Beam

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls

# Your Gmail address + a fresh 16-char App Password (NOT your normal password).
# Requires 2-Step Verification enabled on the Google account.
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your_16char_app_password

# Gmail requires the From address to match the authenticated account.
MAIL_FROM_ADDRESS="${MAIL_USERNAME}"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────────────
# Notes
# • Port 587 + tls is the right combo for Gmail. (Alternative: PORT=465 with
#   MAIL_ENCRYPTION=ssl.)
# • After editing .env always run:  php artisan config:clear
# • Test without sending real mail first: set MAIL_MAILER=log and check
#   storage/logs/laravel.log — then switch back to smtp.
# • Gmail caps sending (~500/day). For real volume use Mailgun / Postmark / SES.
# • Emails send inline on the request. To avoid slowing downloads/registration,
#   set QUEUE_CONNECTION=database (+ run `php artisan queue:work`) and the
#   Mailables (already `implements ShouldQueue`-ready via Queueable) will queue.
# ─────────────────────────────────────────────────────────────────────────────
