# ─────────────────────────────────────────────────────────────────────────────
# Safepay (Pakistan) payments — copy into backend/.env and fill in.
# Without these keys the app runs in DEMO mode (Upgrade activates instantly,
# no real payment) so local testing still works.
#
# Get FREE sandbox keys: https://safepay.pk → sign up → Dashboard → Developers.
# Sandbox needs no business documents — perfect for testing.
# ─────────────────────────────────────────────────────────────────────────────

SAFEPAY_ENV=sandbox                 # sandbox | production
SAFEPAY_API_KEY=sec_xxxxxxxxxxxx    # "API key" / public client key from the dashboard
SAFEPAY_SECRET=xxxxxxxxxxxx         # shared/merchant secret (server-side)
SAFEPAY_WEBHOOK_SECRET=             # optional — set if you enable webhook signing
SAFEPAY_CURRENCY=PKR

# Make sure APP_URL is your real host so Safepay can redirect back:
#   APP_URL=http://localhost:8000
#
# After editing .env:  php artisan config:clear
#
# Test cards (sandbox): 4242 4242 4242 4242, any future expiry, any CVV.
# Sandbox also lets you simulate JazzCash / Easypaisa.
