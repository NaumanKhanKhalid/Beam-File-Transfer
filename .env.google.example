# ──────────────────────────────────────────────────────────────────
# "Continue with Google" sign-in — copy into backend/.env and fill in.
# Without these keys the button shows a friendly "not configured yet"
# message, so the rest of the app still works.
#
# Get keys: https://console.cloud.google.com → APIs & Services →
# Credentials → Create credentials → OAuth client ID → Web application.
# Add the redirect URI below to "Authorized redirect URIs".
# ──────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxx

# Must EXACTLY match an authorized redirect URI in the Google console.
# Defaults to <APP_URL>/auth/google/callback if left unset.
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
